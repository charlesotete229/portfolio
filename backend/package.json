{
  "name": "charles-otete-portfolio-backend",
  "version": "1.0.0",
  "description": "Backend Nest.js pour le formulaire de contact du portfolio",
  "main": "dist/main.js",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start:prod": "npm run build && npm run start"
  },
  "dependencies": {
    "@nestjs/common": "^10.2.0",
    "@nestjs/core": "^10.2.0",
    "@nestjs/platform-express": "^10.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^17.4.2",
    "nodemailer": "^9.0.3",
    "reflect-metadata": "^0.1.13",
    "resend": "^6.17.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/nodemailer": "^8.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
